{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "esnext",
    "lib": ["esnext"],
    "types": ["node"],
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "strict": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "skipLibCheck": true
  },
  // TECH DEBT: ts-node (v10) does not support module: nodenext.
  // This override forces CJS + node10 for dev execution only.
  // ignoreDeprecations silences the TS6 deprecation of node10 moduleResolution.
  // Resolution: migrate backend to "type": "module" (ESM) to eliminate this block.
  "ts-node": {
    "transpileOnly": true,
    "compilerOptions": {
      "module": "CommonJS",
      "moduleResolution": "node10",
      "ignoreDeprecations": "6.0"
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "src/generated"]
}
