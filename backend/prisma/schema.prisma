generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  COMMITTEE_ADMIN
}

enum MasjidStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum SignupRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PaymentMode {
  CASH
  ONLINE
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REVERSED
}

model Masjid {
  id           String       @id @default(uuid())
  code         String       @unique
  name         String
  address      String?
  contactPhone String?
  status       MasjidStatus @default(PENDING)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  users               User[]
  members             Member[]
  contributionPlans   ContributionPlan[]
  payments            Payment[]
  receipts            Receipt[]
  auditLogs           AuditLog[]
  otpSessions         OtpSession[]
}

model MasjidSignupRequest {
  id            String             @id @default(uuid())
  masjidName    String
  location      String
  applicantName String
  phone         String
  notes         String?
  status        SignupRequestStatus @default(PENDING)
  rejectionNote String?
  reviewedAt    DateTime?
  reviewedById  String?
  createdAt     DateTime           @default(now())

  reviewedBy User? @relation(fields: [reviewedById], references: [id])
}

// One plan per fee tier within a masjid (e.g. "General Member", "Chelav").
// Formerly a single per-masjid fee; now scoped to plans so rates vary by category.
model ContributionPlan {
  id          String   @id @default(uuid())
  masjidId    String
  name        String
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  masjid            Masjid                   @relation(fields: [masjidId], references: [id])
  members           Member[]
  feeHistory        ContributionFeeHistory[]
  memberPlanHistory MemberPlanHistory[]

  @@unique([masjidId, name])
}

model ContributionFeeHistory {
  id                 String   @id @default(uuid())
  contributionPlanId String
  monthlyFee         Decimal  @db.Decimal(10, 2)
  effectiveFrom      DateTime
  createdAt          DateTime @default(now())

  contributionPlan ContributionPlan @relation(fields: [contributionPlanId], references: [id])

  @@map("contribution_fee_history")
}

model User {
  id                 String   @id @default(uuid())
  masjidId           String?
  name               String
  username           String
  passwordHash       String
  role               UserRole
  active             Boolean  @default(true)
  mustChangePassword Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  masjid Masjid? @relation(fields: [masjidId], references: [id])

  recordedPayments       Payment[]            @relation("RecordedBy")
  auditLogs              AuditLog[]           @relation("AuditActor")
  reviewedSignupRequests MasjidSignupRequest[]

  @@unique([masjidId, username])
}

model Member {
  id                    String    @id @default(uuid())
  masjidId              String
  memberCode            String
  name                  String
  phone                 String
  address               String?
  contributionStartDate DateTime
  contributionPlanId    String
  openingDueBalance     Decimal   @default(0) @db.Decimal(10, 2)
  appActivated          Boolean   @default(false)
  lastLoginAt           DateTime?
  active                Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  masjid           Masjid           @relation(fields: [masjidId], references: [id])
  contributionPlan ContributionPlan @relation(fields: [contributionPlanId], references: [id])

  payments          Payment[]
  otpSessions       OtpSession[]
  memberPlanHistory MemberPlanHistory[]

  @@unique([masjidId, memberCode])
  @@unique([masjidId, phone])
}

// Immutable log of which plan a member was on and from when.
// The due engine uses this to freeze the correct fee rate per month when
// a member switches plans — historical unpaid months never inherit the new rate.
model MemberPlanHistory {
  id                 String   @id @default(uuid())
  memberId           String
  contributionPlanId String
  effectiveFrom      DateTime
  createdAt          DateTime @default(now())

  member           Member           @relation(fields: [memberId], references: [id])
  contributionPlan ContributionPlan @relation(fields: [contributionPlanId], references: [id])
}

model Payment {
  id               String        @id @default(uuid())
  masjidId         String
  memberId         String
  amount           Decimal       @db.Decimal(10, 2)
  paymentMode      PaymentMode
  paymentStatus    PaymentStatus
  paymentDate      DateTime?
  recordedByUserId String?
  gatewayOrderId   String?
  gatewayPaymentId String?
  note             String?
  createdAt        DateTime      @default(now())

  masjid         Masjid @relation(fields: [masjidId], references: [id])
  member         Member @relation(fields: [memberId], references: [id])
  recordedByUser User?  @relation("RecordedBy", fields: [recordedByUserId], references: [id])

  allocations PaymentAllocation[]
  receipt     Receipt?

  @@index([memberId])
}

model PaymentAllocation {
  id                String   @id @default(uuid())
  paymentId         String
  contributionMonth DateTime
  amountAllocated   Decimal  @db.Decimal(10, 2)
  createdAt         DateTime @default(now())

  payment Payment @relation(fields: [paymentId], references: [id])
}

model Receipt {
  id            String   @id @default(uuid())
  masjidId      String
  paymentId     String   @unique
  receiptNumber String
  generatedAt   DateTime @default(now())

  masjid  Masjid  @relation(fields: [masjidId], references: [id])
  payment Payment @relation(fields: [paymentId], references: [id])

  // Per-masjid sequential receipt numbers (RCP-0001 for masjid A can coexist with RCP-0001 for masjid B).
  @@unique([masjidId, receiptNumber])
}

model AuditLog {
  id         String   @id @default(uuid())
  masjidId   String
  actorId    String
  action     String
  entityType String
  entityId   String
  oldValue   Json?
  newValue   Json?
  createdAt  DateTime @default(now())

  masjid Masjid @relation(fields: [masjidId], references: [id])
  actor  User   @relation("AuditActor", fields: [actorId], references: [id])
}

model OtpSession {
  id           String    @id @default(uuid())
  memberId     String
  masjidId     String
  phone        String
  otpHash      String
  expiresAt    DateTime
  verified     Boolean   @default(false)
  attemptCount Int       @default(0)
  blockedUntil DateTime?
  lastSentAt   DateTime  @default(now())
  createdAt    DateTime  @default(now())

  member Member @relation(fields: [memberId], references: [id])
  masjid Masjid @relation(fields: [masjidId], references: [id])

  @@unique([masjidId, phone])
}
