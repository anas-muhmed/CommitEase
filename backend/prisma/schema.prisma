generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  COMMITTEE_ADMIN
}

enum MasjidStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum SignupRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PaymentMode {
  CASH
  ONLINE
  BANK_TRANSFER
  UPI
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REVERSED
}

enum FundAccountType {
  CASH
  BANK
  UPI
}

enum ExpenseType {
  MOSQUE_PAID
  PERSONAL_PAID
}

enum ExpenseStatus {
  SETTLED
  PENDING_REIMB
  REIMBURSED
}

enum ExpenseCategory {
  UTILITIES
  MAINTENANCE
  SUPPLIES
  SALARIES
  EVENTS
  DONATIONS
  OTHER
}

enum CommitteeRole {
  VIEWER
  PAYMENT_OPERATOR
  TREASURER
  ADMIN
}

enum TreasuryEntryType {
  INCOME
  EXPENSE
  REIMBURSEMENT
  RESERVE_IN
  RESERVE_OUT
  ADJUSTMENT
  TRANSFER
  REVERSAL
}

enum LedgerDirection {
  CREDIT
  DEBIT
}

enum ChelavStatus {
  ASSIGNED
  COMPLETED
  SKIPPED
  SWAPPED
}

model Masjid {
  id           String       @id @default(uuid())
  code         String       @unique
  name         String
  address      String?
  contactPhone String?
  status       MasjidStatus @default(PENDING)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  users               User[]
  members             Member[]
  contributionPlans   ContributionPlan[]
  payments            Payment[]
  receipts            Receipt[]
  paymentReversals    PaymentReversal[]
  auditLogs           AuditLog[]
  otpSessions         OtpSession[]
  fundAccounts        FundAccount[]
  fundReserves        FundReserve[]
  treasuryLedger      TreasuryLedger[]
  expenses            Expense[]
  memberSummaries     MemberFinancialSummary[]
  receiptSequence     ReceiptSequence?
  chelavSchedules     ChelavSchedule[]
}

model MasjidSignupRequest {
  id            String             @id @default(uuid())
  masjidName    String
  location      String
  applicantName String
  phone         String
  notes         String?
  status        SignupRequestStatus @default(PENDING)
  rejectionNote String?
  reviewedAt    DateTime?
  reviewedById  String?
  createdAt     DateTime           @default(now())

  reviewedBy User? @relation(fields: [reviewedById], references: [id])
}

// One plan per fee tier within a masjid (e.g. "General Member", "Chelav").
// Formerly a single per-masjid fee; now scoped to plans so rates vary by category.
model ContributionPlan {
  id          String   @id @default(uuid())
  masjidId    String
  name        String
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  masjid            Masjid                   @relation(fields: [masjidId], references: [id])
  members           Member[]
  feeHistory        ContributionFeeHistory[]
  memberPlanHistory MemberPlanHistory[]

  @@unique([masjidId, name])
}

model ContributionFeeHistory {
  id                 String   @id @default(uuid())
  contributionPlanId String
  monthlyFee         Decimal  @db.Decimal(10, 2)
  effectiveFrom      DateTime
  createdAt          DateTime @default(now())

  contributionPlan ContributionPlan @relation(fields: [contributionPlanId], references: [id])

  @@map("contribution_fee_history")
}

model User {
  id                 String        @id @default(uuid())
  masjidId           String?
  name               String
  username           String
  passwordHash       String
  role               UserRole
  committeeRole      CommitteeRole @default(ADMIN)
  active             Boolean       @default(true)
  mustChangePassword Boolean       @default(true)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  masjid Masjid? @relation(fields: [masjidId], references: [id])

  recordedPayments       Payment[]            @relation("RecordedBy")
  paymentReversals       PaymentReversal[]    @relation("ReversedBy")
  auditLogs              AuditLog[]           @relation("AuditActor")
  reviewedSignupRequests MasjidSignupRequest[]
  fundAccountsCreated    FundAccount[]        @relation("FundAccountCreatedBy")
  fundReservesCreated    FundReserve[]        @relation("FundReserveCreatedBy")
  treasuryLedgerEntries  TreasuryLedger[]     @relation("TreasuryLedgerCreatedBy")
  expensesPaid           Expense[]            @relation("ExpensePaidBy")
  expensesRecorded       Expense[]            @relation("ExpenseRecordedBy")

  @@unique([masjidId, username])
}

model Member {
  id                    String    @id @default(uuid())
  masjidId              String
  memberCode            String
  name                  String
  phone                 String
  address               String?
  contributionStartDate DateTime
  contributionPlanId    String
  openingDueBalance     Decimal   @default(0) @db.Decimal(10, 2)
  appActivated          Boolean   @default(false)
  lastLoginAt           DateTime?
  active                Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  chelavParticipation Boolean   @default(true)

  masjid           Masjid           @relation(fields: [masjidId], references: [id])
  contributionPlan ContributionPlan @relation(fields: [contributionPlanId], references: [id])

  payments          Payment[]
  otpSessions       OtpSession[]
  memberPlanHistory MemberPlanHistory[]
  financialSummary  MemberFinancialSummary?
  chelavSchedules   ChelavSchedule[]

  @@unique([masjidId, memberCode])
  @@unique([masjidId, phone])
}

// Immutable log of which plan a member was on and from when.
// The due engine uses this to freeze the correct fee rate per month when
// a member switches plans — historical unpaid months never inherit the new rate.
model MemberPlanHistory {
  id                 String   @id @default(uuid())
  memberId           String
  contributionPlanId String
  effectiveFrom      DateTime
  createdAt          DateTime @default(now())

  member           Member           @relation(fields: [memberId], references: [id])
  contributionPlan ContributionPlan @relation(fields: [contributionPlanId], references: [id])
}

model Payment {
  id               String        @id @default(uuid())
  masjidId         String
  memberId         String
  amount           Decimal       @db.Decimal(10, 2)
  paymentMode      PaymentMode
  paymentStatus    PaymentStatus
  paymentDate      DateTime?
  recordedByUserId String?
  fundAccountId    String?
  gatewayOrderId   String?
  gatewayPaymentId String?
  note             String?
  createdAt        DateTime      @default(now())

  masjid         Masjid       @relation(fields: [masjidId], references: [id])
  member         Member       @relation(fields: [memberId], references: [id])
  recordedByUser User?        @relation("RecordedBy", fields: [recordedByUserId], references: [id])
  fundAccount    FundAccount? @relation(fields: [fundAccountId], references: [id])

  allocations PaymentAllocation[]
  receipt     Receipt?
  reversal    PaymentReversal?

  @@index([memberId])
  @@index([fundAccountId])
}

model PaymentAllocation {
  id                String    @id @default(uuid())
  paymentId         String
  contributionMonth DateTime? // NULL = opening-balance payment (clears openingDueBalance)
  amountAllocated   Decimal   @db.Decimal(10, 2)
  createdAt         DateTime  @default(now())

  payment Payment @relation(fields: [paymentId], references: [id])
}

model Receipt {
  id            String    @id @default(uuid())
  masjidId      String
  paymentId     String    @unique
  receiptNumber String
  generatedAt   DateTime  @default(now())
  voidedAt      DateTime?

  masjid  Masjid  @relation(fields: [masjidId], references: [id])
  payment Payment @relation(fields: [paymentId], references: [id])

  // Per-masjid sequential receipt numbers (RCP-0001 for masjid A can coexist with RCP-0001 for masjid B).
  @@unique([masjidId, receiptNumber])
}

// Immutable record created when a payment is reversed or transferred.
// @@unique([paymentId]) enforces one reversal per payment (Rule 1: already-reversed → 409).
model PaymentReversal {
  id         String   @id @default(uuid())
  paymentId  String   @unique
  masjidId   String
  reversedBy String
  reason     String
  reversedAt DateTime @default(now())

  payment Payment @relation(fields: [paymentId], references: [id])
  masjid  Masjid  @relation(fields: [masjidId], references: [id])
  actor   User    @relation("ReversedBy", fields: [reversedBy], references: [id])

  @@map("payment_reversals")
}

model AuditLog {
  id         String   @id @default(uuid())
  masjidId   String
  actorId    String
  action     String
  entityType String
  entityId   String
  oldValue   Json?
  newValue   Json?
  createdAt  DateTime @default(now())

  masjid Masjid @relation(fields: [masjidId], references: [id])
  actor  User   @relation("AuditActor", fields: [actorId], references: [id])
}

model OtpSession {
  id           String    @id @default(uuid())
  memberId     String
  masjidId     String
  phone        String
  otpHash      String
  expiresAt    DateTime
  verified     Boolean   @default(false)
  attemptCount Int       @default(0)
  blockedUntil DateTime?
  lastSentAt   DateTime  @default(now())
  createdAt    DateTime  @default(now())

  member Member @relation(fields: [memberId], references: [id])
  masjid Masjid @relation(fields: [masjidId], references: [id])

  @@unique([masjidId, phone])
}

// ── Treasury ──────────────────────────────────────────────────────────────────

model FundAccount {
  id             String          @id @default(uuid())
  masjidId       String
  name           String
  type           FundAccountType
  currentBalance Decimal         @default(0) @db.Decimal(12, 2)
  active         Boolean         @default(true)
  createdByUserId String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  masjid        Masjid           @relation(fields: [masjidId], references: [id])
  createdBy     User             @relation("FundAccountCreatedBy", fields: [createdByUserId], references: [id])
  ledgerEntries TreasuryLedger[]
  payments      Payment[]
  expensesPaidFrom     Expense[] @relation("ExpensePaidFrom")
  expensesReimbursedFrom Expense[] @relation("ExpenseReimbursedFrom")

  @@unique([masjidId, name])
  @@index([masjidId, active])
}

model FundReserve {
  id               String   @id @default(uuid())
  masjidId         String
  title            String
  purpose          String?
  amount           Decimal  @default(0) @db.Decimal(12, 2)
  active           Boolean  @default(true)
  restricted       Boolean  @default(false)
  approvalRequired Boolean  @default(false)
  createdByUserId  String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  masjid    Masjid @relation(fields: [masjidId], references: [id])
  createdBy User   @relation("FundReserveCreatedBy", fields: [createdByUserId], references: [id])

  @@unique([masjidId, title])
  @@index([masjidId, active])
}

// ── Expenses ──────────────────────────────────────────────────────────────────
// MOSQUE_PAID: paid from a fund account → balance decrements + EXPENSE ledger entry.
// PERSONAL_PAID: committee member paid personally → status=PENDING_REIMB, no balance change yet.
// On reimbursement: status→REIMBURSED, source balance decrements + REIMBURSEMENT ledger entry.

model Expense {
  id               String          @id @default(uuid())
  masjidId         String
  expenseType      ExpenseType
  status           ExpenseStatus
  category         ExpenseCategory
  amount           Decimal         @db.Decimal(12, 2)
  description      String?

  // MOSQUE_PAID: which account was debited
  fundAccountId    String?

  // PERSONAL_PAID: who paid out of pocket
  paidByUserId     String?

  // Reimbursement fields (filled when status → REIMBURSED)
  reimbursedAt         DateTime?
  reimbursedFromId     String?

  recordedByUserId String
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  masjid         Masjid       @relation(fields: [masjidId],         references: [id])
  fundAccount    FundAccount? @relation("ExpensePaidFrom",          fields: [fundAccountId],    references: [id])
  reimbursedFrom FundAccount? @relation("ExpenseReimbursedFrom",    fields: [reimbursedFromId], references: [id])
  paidBy         User?        @relation("ExpensePaidBy",            fields: [paidByUserId],     references: [id])
  recordedBy     User         @relation("ExpenseRecordedBy",        fields: [recordedByUserId], references: [id])

  @@index([masjidId, createdAt])
  @@index([masjidId, status])
}

// ── Member Financial Summary (precomputed cache) ──────────────────────────────
// Updated fire-and-forget after payment events. Used as a fast-path for list
// rendering without re-computing the full ledger per member.

model MemberFinancialSummary {
  memberId          String   @id
  masjidId          String
  totalOutstanding  Decimal  @default(0) @db.Decimal(12, 2)
  overdueMonths     Int      @default(0)
  healthScore       Int      @default(100)
  healthGrade       String   @default("EXCELLENT")
  lastPaymentAt     DateTime?
  totalPaidLifetime Decimal  @default(0) @db.Decimal(12, 2)
  paidThisMonth     Boolean  @default(false)
  computedAt        DateTime @default(now())

  member Member @relation(fields: [memberId], references: [id])
  masjid Masjid @relation(fields: [masjidId], references: [id])

  @@index([masjidId])
}

// ── Treasury Ledger ───────────────────────────────────────────────────────────
// Immutable account-level audit trail. Every balance mutation writes one entry.
// Transfers produce two entries (DEBIT on source, CREDIT on destination).
// Source of truth for balance = SUM of FundAccount.currentBalance; ledger is for history.

model TreasuryLedger {
  id              String            @id @default(uuid())
  masjidId        String
  accountId       String
  entryType       TreasuryEntryType
  direction       LedgerDirection
  amount          Decimal           @db.Decimal(12, 2)
  referenceId     String?
  referenceType   String?
  note            String?
  createdByUserId String
  createdAt       DateTime          @default(now())

  masjid    Masjid      @relation(fields: [masjidId],        references: [id])
  account   FundAccount @relation(fields: [accountId],       references: [id])
  createdBy User        @relation("TreasuryLedgerCreatedBy", fields: [createdByUserId], references: [id])

  @@index([masjidId, createdAt])
  @@index([accountId, createdAt])
  @@index([masjidId, entryType, createdAt])
}

// ── Receipt Sequence ──────────────────────────────────────────────────────────
// Per-masjid atomic counter for sequential receipt numbers.
// UPSERT inside a transaction guarantees unique RCP-NNNNN under concurrent writes.

model ReceiptSequence {
  masjidId   String @id
  lastNumber Int    @default(0)

  masjid Masjid @relation(fields: [masjidId], references: [id])
}

// ── Chelav Schedule ───────────────────────────────────────────────────────────
// One row per day. memberId is optional so household/non-member labels work.
// displayLabel is always set — auto-populated from member.name when memberId is
// provided. swappedWithId is a plain string ref (no Prisma relation) to avoid
// circular self-relation complexity.

model ChelavSchedule {
  id            String       @id @default(uuid())
  masjidId      String
  memberId      String?
  displayLabel  String
  date          DateTime     @db.Date
  status        ChelavStatus @default(ASSIGNED)
  notes         String?
  swappedWithId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  masjid Masjid  @relation(fields: [masjidId], references: [id])
  member Member? @relation(fields: [memberId], references: [id], onDelete: SetNull)

  @@unique([masjidId, date])
  @@index([masjidId, date])
}
